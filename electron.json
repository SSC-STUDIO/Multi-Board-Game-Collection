{
  "name": "board-games",
  "productName": "多棋类合集 · Board Games",
  "version": "1.0.0",
  "description": "五子棋、围棋、国际象棋、中国象棋和军棋翻翻棋合一的多棋类游戏平台",
  "main": "electron-main.js",
  "author": "Your Name",
  "license": "MIT",
  "build": {
    "appId": "com.yourcompany.gomoku",
    "productName": "多棋类合集 · Board Games",
    "directories": {
      "output": "builds/desktop",
      "buildResources": "assets/icons"
    },
    "files": [
      "index.html",
      "src/**/*",
      "assets/**/*",
      "locales/**/*",
      "steam/**/*",
      "version.json",
      "electron-preload.js",
      "electron-main.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "assets/icons/icon_256x256.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icons/icon_256x256.png",
      "uninstallerIcon": "assets/icons/icon_256x256.png",
      "installerHeaderIcon": "assets/icons/icon_48x48.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "多棋类合集"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icons/icon_512x512.png",
      "category": "public.app-category.board-games"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons/icon_256x256.png",
      "category": "Game",
      "maintainer": "your@email.com",
      "desktop": {
        "Name": "Board Games",
        "Comment": "Multi-board game collection",
        "Categories": "Game;BoardGame;"
      }
    },
    "steam": {
      "steamAppId": "YOUR_STEAM_APP_ID",
      "steamGameDir": "builds/steam",
      "steamDepots": {
        "windows": {
          "depotId": "YOUR_WINDOWS_DEPOT_ID",
          "contents": [
            "**/*"
          ]
        },
        "macos": {
          "depotId": "YOUR_MACOS_DEPOT_ID",
          "contents": [
            "**/*"
          ]
        },
        "linux": {
          "depotId": "YOUR_LINUX_DEPOT_ID",
          "contents": [
            "**/*"
          ]
        }
      }
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
