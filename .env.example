# 环境配置文件
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=五子棋
APP_VERSION=1.0.0

# Steam配置
STEAM_APP_ID=YOUR_STEAM_APP_ID
STEAM_API_KEY=YOUR_STEAM_API_KEY

# 构建配置
BUILD_NUMBER=1
BUILD_ENV=development

# 服务器配置(如果需要在线功能)
SERVER_HOST=localhost
SERVER_PORT=3000

# 调试配置
DEBUG_MODE=true
ENABLE_LOGGING=true

# 分析配置(可选)
GOOGLE_ANALYTICS_ID=
SENTRY_DSN=
