{
  "cloud": {
    "enabled": true,
    "maxFileSizeKB": 1024,
    "numFiles": 5,
    "folders": [
      {
        "path": "save/",
        "pattern": "*.json",
        "description": "Game saves and settings"
      }
    ]
  },
  "saveData": {
    "structure": {
      "settings": {
        "language": "en-US",
        "activeGame": "gomoku",
        "boardSize": 15,
        "defaultRule": "classic",
        "defaultMode": "pvp",
        "aiDifficulty": "medium",
        "soundEnabled": true,
        "musicEnabled": true,
        "theme": "default",
        "llmCoach": {
          "enabled": false,
          "provider": "openai",
          "model": "gpt-4",
          "baseUrl": "",
          "apiKey": ""
        }
      },
      "stats": {
        "gomoku": {
          "gamesPlayed": 0,
          "gamesWon": 0,
          "winningStreak": 0
        },
        "go": {
          "gamesPlayed": 0,
          "gamesWon": 0,
          "winningStreak": 0
        },
        "chess": {
          "gamesPlayed": 0,
          "gamesWon": 0,
          "winningStreak": 0
        },
        "xiangqi": {
          "gamesPlayed": 0,
          "gamesWon": 0,
          "winningStreak": 0
        },
        "junqi": {
          "gamesPlayed": 0,
          "gamesWon": 0,
          "winningStreak": 0
        },
        "total": {
          "gamesPlayed": 0,
          "gamesWon": 0,
          "movesMade": 0,
          "achievements": []
        }
      },
      "history": {
        "recentGames": [],
        "favoriteBoards": []
      }
    }
  }
}